const HELIUS_KEY = '0540ab9a-cf07-41f6-af11-9ba53e6b1bca';
const ARKHAM_KEY = 'd3e6745a-9283-4e51-8fdd-da0e70c90aa6';
const CURRENTS_KEY = 'rRvwBLutONQVVE-7asbxMXZM7FTcK02iBn6yZmCHxb9vFm2o';

const HELIUS_RPC = `https://mainnet.helius-rpc.com/?api-key=${HELIUS_KEY}`;
const HELIUS_API = `https://api.helius.xyz/v0`;

export default async function handler(req, res) {
  // CORS — allow requests from anywhere (claude.ai artifact iframe)
  res.setHeader('Access-Control-Allow-Origin', '*');
  res.setHeader('Access-Control-Allow-Methods', 'GET, POST, OPTIONS');
  res.setHeader('Access-Control-Allow-Headers', 'Content-Type');

  if (req.method === 'OPTIONS') {
    return res.status(200).end();
  }

  if (req.method !== 'POST') {
    return res.status(405).json({ error: 'Method not allowed' });
  }

  const { action, payload } = req.body;

  try {
    switch (action) {

      // ── Helius RPC call ──────────────────────────────────────────────
      case 'helius_rpc': {
        const { method, params } = payload;
        const r = await fetch(HELIUS_RPC, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ jsonrpc: '2.0', id: 1, method, params }),
        });
        const data = await r.json();
        return res.status(200).json(data);
      }

      // ── Helius Enhanced TX API ───────────────────────────────────────
      case 'helius_tx': {
        const { signature } = payload;
        const r = await fetch(
          `${HELIUS_API}/transactions?api-key=${HELIUS_KEY}`,
          {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ transactions: [signature] }),
          }
        );
        const data = await r.json();
        return res.status(200).json(data);
      }

      // ── Arkham intelligence lookup ───────────────────────────────────
      case 'arkham': {
        const { address } = payload;
        const r = await fetch(
          `https://api.arkm.com/intelligence/address/${address}/all`,
          { headers: { 'API-Key': ARKHAM_KEY } }
        );
        if (!r.ok) return res.status(200).json({ error: 'Arkham: no data', status: r.status });
        const data = await r.json();
        return res.status(200).json(data);
      }

      // ── Currents news keyword search ─────────────────────────────────
      case 'currents_search': {
        const { keywords, category, limit = 10 } = payload;
        let url = `https://api.currentsapi.services/v1/search?apiKey=${CURRENTS_KEY}&language=en&limit=${limit}`;
        if (keywords) url += `&keywords=${encodeURIComponent(keywords)}`;
        if (category) url += `&category=${encodeURIComponent(category)}`;
        const r = await fetch(url);
        const data = await r.json();
        return res.status(200).json(data);
      }

      default:
        return res.status(400).json({ error: `Unknown action: ${action}` });
    }
  } catch (err) {
    return res.status(500).json({ error: err.message });
  }
}
